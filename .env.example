# ─── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=vitalai
POSTGRES_USER=vitalai
POSTGRES_PASSWORD=changeme          # change this — never commit real passwords

# Connection string (used by the app)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${DB_PORT:-5432}/${POSTGRES_DB}

# Port exposed on the host (change if 5432 is already in use on your machine)
DB_PORT=5432

# ─── App ────────────────────────────────────────────────────────────────────────
PORT=3000
